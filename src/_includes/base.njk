<!doctype html>
<html lang="{{ metadata.language }}">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title + " | " + metadata.title if title else metadata.title }}</title>
		<meta name="description" content="{{ excerpt or description or metadata.description }}">
		<link rel="stylesheet" href="/style.css">
		<link rel="alternate" href="/feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}">
		<link href="/pagefind/pagefind-ui.css" rel="stylesheet">
		<script src="/pagefind/pagefind-ui.js"></script>
		<style>
			{% getBundle "css" %}
		</style>
		<script>
			// Initialize theme safely before body renders
			const savedTheme = localStorage.getItem("theme");
			const validThemes = ["dark", "light", "sepia"];
			if (savedTheme && validThemes.includes(savedTheme)) {
				document.documentElement.setAttribute("data-theme", savedTheme);
			} else if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
				document.documentElement.setAttribute("data-theme", "dark");
			}
		</script>
	</head>
	<body>
		<a href="#skip" class="skip-link">Skip to content</a>
		<div class="app-layout">
			<aside class="sidebar">
				<div class="sidebar-header">
					<a href="/" class="sidebar-title">Steam Deck Guide</a>
					<button id="mobile-menu-close" class="mobile-only" aria-label="Close Menu">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
					</button>
					<button id="desktop-menu-close" class="desktop-only" aria-label="Collapse Sidebar" title="Collapse Sidebar">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="9" x2="9" y1="3" y2="21"/><path d="m16 15-3-3 3-3"/></svg>
					</button>
				</div>
				<nav class="chapter-nav">
					<div class="nav-section-title">Chapters</div>
					<div class="chapter-modules">
						{%- for module in curriculum -%}
							{%- set hasActive = false -%}
							
							{%- for slug in module.slugs -%}
								{%- set post = collections.posts | findBySlug(slug) -%}
								{%- if post and page.url == post.url -%}
									{%- set hasActive = true -%}
								{%- endif -%}
							{%- endfor -%}
							
							{%- if module.slugs.length > 0 -%}
							<details class="module-details" {% if hasActive %}open{% endif %}>
								<summary class="module-summary">{{ module.name }}</summary>
								<ul class="chapter-list module-list">
									{%- for slug in module.slugs -%}
									{%- set post = collections.posts | findBySlug(slug) -%}
									{%- if post -%}
									<li class="chapter-item">
										<a href="{{ post.url }}" 
										   class="chapter-link {% if page.url == post.url %}active{% endif %}"
										   {% if page.url == post.url %}aria-current="page"{% endif %}>
											<span class="chapter-name">{{ post.data.title }}</span>
										</a>
									</li>
									{%- endif -%}
									{%- endfor -%}
								</ul>
							</details>
							{%- endif -%}
						{%- endfor -%}
					</div>
				</nav>
			</aside>

			<div class="container">
				<header>
					<button id="mobile-menu-open" class="mobile-only" aria-label="Open Menu">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
					</button>
					<button id="desktop-menu-open" class="desktop-only" aria-label="Expand Sidebar" title="Expand Sidebar">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="9" x2="9" y1="3" y2="21"/><path d="m14 9 3 3-3 3"/></svg>
					</button>
					<a href="/" class="home-link">{{ metadata.title }}</a>
					<div class="search-wrapper">
						<div id="search"></div>
					</div>
					<ul class="nav">
						<li class="nav-item"><a href="/" {% if page.url == '/' %}aria-current="page"{% endif %}>Home</a></li>
						<li class="nav-item"><a href="/start-here/" {% if page.url == '/start-here/' %}aria-current="page"{% endif %}>Start Here</a></li>
						<li class="nav-item"><a href="/posts/" {% if page.url == '/posts/' %}aria-current="page"{% endif %}>Archive</a></li>
						<li class="nav-item"><a href="/about/" {% if page.url == '/about/' %}aria-current="page"{% endif %}>About</a></li>
						<li class="nav-item">
							<select id="theme-select" aria-label="Select color theme">
								<option value="light">Light</option>
								<option value="dark">Dark</option>
								<option value="sepia">Sepia</option>
							</select>
						</li>
					</ul>
				</header>

				<main id="skip">
					<div class="content-wrapper">
						<div class="post-content" data-pagefind-body>
							{{ content | safe }}
						</div>
						{% if tags and "posts" in tags %}
						<aside class="toc-sidebar">
							<div class="toc-sticky">
								<div class="nav-section-title">On This Page</div>
								{{ content | toc | safe }}
							</div>
						</aside>
						{% endif %}
					</div>

					{% if tags and "posts" in tags %}
					<nav class="pagination-nav">
						{%- set previousPost = collections.posts | getPreviousCollectionItem(page) %}
						{%- set nextPost = collections.posts | getNextCollectionItem(page) %}
						
						{%- if previousPost %}
						<a href="{{ previousPost.url }}" class="pagination-link previous">
							<span class="pagination-label">Previous Chapter</span>
							<span class="pagination-title">{{ previousPost.data.title }}</span>
						</a>
						{% else %}
						<div class="pagination-spacer"></div>
						{%- endif %}

						{%- if nextPost %}
						<a href="{{ nextPost.url }}" class="pagination-link next">
							<span class="pagination-label">Next Chapter</span>
							<span class="pagination-title">{{ nextPost.data.title }}</span>
						</a>
						{% endif %}
					</nav>
					{% endif %}
				</main>

				<footer>
					<p>&copy; {{ metadata.author.name }}. All rights reserved.</p>
					<p>Built with <a href="https://www.11ty.dev/">11ty</a></p>
				</footer>
			</div>
		</div>
		<script>
			// Theme Selection
			const themeSelect = document.getElementById('theme-select');
			
			// Set initial value
			const initialTheme = document.documentElement.getAttribute('data-theme') || 'light';
			themeSelect.value = initialTheme;

			themeSelect.addEventListener('change', (e) => {
				const newTheme = e.target.value;
				document.documentElement.setAttribute('data-theme', newTheme);
				localStorage.setItem('theme', newTheme);
			});

			// Mobile Menu Toggle
			const mobileMenuOpen = document.getElementById('mobile-menu-open');
			const mobileMenuClose = document.getElementById('mobile-menu-close');
			const sidebar = document.querySelector('.sidebar');

			if (mobileMenuOpen && mobileMenuClose && sidebar) {
				mobileMenuOpen.addEventListener('click', () => {
					sidebar.classList.add('sidebar-open');
					document.body.style.overflow = 'hidden'; // Prevent background scrolling
				});

				mobileMenuClose.addEventListener('click', () => {
					sidebar.classList.remove('sidebar-open');
					document.body.style.overflow = '';
				});
			}

			// Desktop Sidebar Toggle
			const desktopMenuOpen = document.getElementById('desktop-menu-open');
			const desktopMenuClose = document.getElementById('desktop-menu-close');
			const appLayout = document.querySelector('.app-layout');

			if (desktopMenuOpen && desktopMenuClose && appLayout) {
				desktopMenuClose.addEventListener('click', () => {
					appLayout.classList.add('sidebar-collapsed-desktop');
					localStorage.setItem('sidebarCollapsed', 'true');
				});

				desktopMenuOpen.addEventListener('click', () => {
					appLayout.classList.remove('sidebar-collapsed-desktop');
					localStorage.setItem('sidebarCollapsed', 'false');
				});

				// Restore state
				if (localStorage.getItem('sidebarCollapsed') === 'true') {
					appLayout.classList.add('sidebar-collapsed-desktop');
				}
			}

			// Initialize Pagefind Search
			window.addEventListener('DOMContentLoaded', (event) => {
				if (typeof PagefindUI !== 'undefined') {
					new PagefindUI({ element: "#search", showSubResults: true, baseUrl: "/" });
				}
			});

			// Copy Code Button
			const preBlocks = document.querySelectorAll('pre');
			preBlocks.forEach((pre) => {
				const button = document.createElement('button');
				button.className = 'copy-btn';
				button.innerText = 'Copy';
				pre.appendChild(button);

				button.addEventListener('click', async () => {
					const code = pre.querySelector('code');
					if (code) {
						await navigator.clipboard.writeText(code.innerText);
						button.innerText = 'Copied!';
						setTimeout(() => {
							button.innerText = 'Copy';
						}, 2000);
					}
				});
			});
		</script>
	</body>
</html>
