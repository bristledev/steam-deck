---
permalink: /posts/index.html
layout: base.njk
title: Archive
---

<h1>Archive</h1>

<ul class="postlist">
{%- for post in collections.posts | reverse -%}
	<li class="postlist-item">
		<a href="{{ post.url }}" class="postlist-link">{{ post.data.title }}</a>
		<div class="post-metadata">
			<span class="postlist-date">{{ post.date | readableDate }}</span>
			<span class="reading-time">⏱️ {{ post.templateContent | striptags | readingTime }}</span>
		</div>
	</li>
{%- endfor -%}
</ul>
